{
  "name": "sol-101-web",
  "private": true,
  "version": "1.0.0",
  "description": "SOL-101: A specialized marketplace and forum platform for the Solana ecosystem.",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "clean": "rm -rf dist .vite",
    "preview": "vite preview",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "test:smoke": "node --experimental-strip-types --test tests/*.test.mjs",
    "format": "prettier --write \"src/**/*.{ts,tsx,css,md}\"",
    "validate": "bash scripts/validate-project.sh",
    "metadata:export": "node scripts/export-shop-metadata-snapshot.mjs",
    "solana:build": "anchor build",
    "solana:sync-idl": "node scripts/sync-onchain-idl.mjs",
    "solana:sync-market-idl": "node scripts/sync-onchain-market-idl.mjs",
    "solana:create-mint": "node --experimental-strip-types scripts/create-duan-mint.ts",
    "solana:sync-shop": "node --experimental-strip-types scripts/sync-onchain-shop.ts",
    "solana:set-game-authority": "node --experimental-strip-types scripts/set-game-authority.ts",
    "solana:bootstrap": "npm run solana:build && npm run solana:sync-idl && npm run solana:sync-market-idl && npm run solana:sync-shop"
  },
