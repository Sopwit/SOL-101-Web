{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://sol-101.local/schemas/shop-metadata.schema.json",
  "title": "SOL-101 Shop Metadata Manifest",
  "type": "object",
  "required": ["version", "generatedAt", "source", "schema", "items", "legacyIds"],
  "properties": {
    "version": {
      "type": "integer",
      "minimum": 1
    },
    "generatedAt": {
      "type": "string",
      "format": "date-time"
    },
    "source": {
      "type": "string"
    },
    "schema": {
      "type": "string"
    },
    "legacyIds": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "items": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "id",
          "name",
          "description",
          "category",
          "rarity",
          "imageUrl",
          "version",
          "updatedAt"
        ],
        "properties": {
          "id": {
            "type": "string"
          },
          "name": {
            "type": "string"
          },
          "description": {
            "type": "string"
          },
          "category": {
            "type": "string"
          },
          "rarity": {
            "type": "string",
            "enum": ["common", "rare", "epic", "legendary"]
          },
          "imageUrl": {
            "type": "string"
          },
          "version": {
            "type": "integer",
            "minimum": 1
          },
          "updatedAt": {
            "type": "string",
            "format": "date-time"
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
